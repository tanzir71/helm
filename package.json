{
  "name": "helm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "packageExtensions": {
      "@openrouter/ai-sdk-provider@1.5.4": {
        "dependencies": {
          "@ai-sdk/provider": "2.0.3"
        }
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean",
    "eval": "pnpm --filter @helm/core eval --",
    "lint": "eslint . && prettier --check . && pnpm lint:tokens",
    "lint:tokens": "node scripts/verify-webview-tokens.mjs",
    "package": "pnpm --filter ./packages/extension package",
    "site:build": "node site/build.mjs",
    "site:check": "node site/check.mjs",
    "site:verify": "pnpm site:build && pnpm site:check",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm --filter @helm/core build && pnpm -r --if-present typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
