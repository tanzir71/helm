{
  "name": "helm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean",
    "eval": "pnpm --filter @helm/core eval --",
    "lint": "eslint . && prettier --check .",
    "package": "pnpm --filter ./packages/extension package",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm --filter @helm/core build && pnpm -r --if-present typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
