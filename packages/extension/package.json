{
  "name": "helm",
  "displayName": "Helm",
  "description": "Beginner-friendly BYOK coding agent",
  "version": "0.1.0",
  "private": true,
  "publisher": "helm-local",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onView:helm.chatView",
    "onCommand:helm.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "helm.openChat",
        "title": "Helm: Open Chat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "helm",
          "title": "Helm",
          "icon": "media/helm.svg"
        }
      ]
    },
    "views": {
      "helm": [
        {
          "type": "webview",
          "id": "helm.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Helm",
      "properties": {
        "helm.enterBehavior": {
          "type": "string",
          "enum": [
            "queue",
            "steer"
          ],
          "default": "queue",
          "description": "What Enter does while an agent run is active."
        },
        "helm.utilityModel": {
          "type": "string",
          "default": "",
          "description": "Optional inexpensive model for summaries and suggestions."
        },
        "helm.web.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Helm's built-in web search and safe page fetch tools."
        },
        "helm.web.searchProvider": {
          "type": "string",
          "enum": [
            "tavily",
            "brave",
            "exa",
            "duckduckgo"
          ],
          "default": "duckduckgo",
          "description": "Search provider used by Helm's built-in web search tool."
        }
      }
    }
  },
  "scripts": {
    "build": "pnpm --filter @helm/webview build && node esbuild.mjs",
    "build:test": "tsc -p tsconfig.test.json",
    "clean": "rm -rf dist .vscode-test",
    "package": "pnpm build && mkdir -p ../../dist && vsce package --no-dependencies --out ../../dist/helm-0.1.0.vsix",
    "test": "vitest run tests",
    "test:integration": "pnpm build && pnpm build:test && node ./dist-test/runTest.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@helm/core": "workspace:*",
    "@types/mocha": "^10.0.0",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "mocha": "^11.0.0"
  }
}
